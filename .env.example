# Copy to `.env` and fill in. Django loads this from the repo root.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Single PostgreSQL database for local dev. After `scripts/deploy/0_pull_prod_to_local.bat`,
# this DB contains multiple schemas (public legacy data + ecothrift V3 app). Django uses
# `search_path=ecothrift` — point ORM at V3 tables only. Category exports use `public.*`
# and `ecothrift.*` in SQL; same DATABASE_* connection.
DATABASE_NAME=ecothrift_v2
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Optional
ANTHROPIC_API_KEY=
