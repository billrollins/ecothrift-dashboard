# Copy to `.env` and fill in. Django loads this from the repo root.

SECRET_KEY=change-me
DEBUG=True
# development = manifest API timing logs under workspace/b-manifest-api/ (see ecothrift/settings.py)
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1

# Single PostgreSQL database for local dev. After `scripts/deploy/0_pull_prod_to_local.bat`,
# this DB contains multiple schemas (public legacy + ecothrift V3 app). Django uses
# `search_path=ecothrift` — point ORM at V3 tables only. Category exports use `public.*`
# and `ecothrift.*` in SQL; same DATABASE_* connection.
DATABASE_NAME=ecothrift_v3
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Production database (optional; for running management commands against prod from local machine).
# When PROD_DATABASE_NAME is set, Django exposes alias "production" — use --database production on commands.
# PROD_DATABASE_NAME=
# PROD_DATABASE_HOST=
# PROD_DATABASE_PORT=5432
# PROD_DATABASE_USER=
# PROD_DATABASE_PASSWORD=

# Optional
ANTHROPIC_API_KEY=
# Default Claude model for most AI features (buying manifests, inventory AI, chat proxy, etc.)
AI_MODEL=claude-sonnet-4-6
# Cheaper/faster model (e.g. suggest_item, title category estimates). Use claude-haiku-4-5 — there is no claude-haiku-4-6.
AI_MODEL_FAST=claude-haiku-4-5

# B-Stock / apps/buying (see initiative bstock_auction_intelligence.md)
# Preferred: run `python manage.py bstock_token` (stores JWT in workspace/.bstock_token, gitignored).
# Fallback: JWT here if you do not use the token file.
BSTOCK_AUTH_TOKEN=
# Delay between search pagination requests (seconds); 0 = fastest sweep
BUYING_REQUEST_DELAY_SECONDS=0
# Overlap HTTP fetch for next auction while post-processing current (manifest pull queue)
MANIFEST_PULL_PREFETCH=True
# Retries on HTTP 429 (exponential backoff)
BSTOCK_MAX_RETRIES=3
# Safety cap on search pagination pages per marketplace per run
BSTOCK_SEARCH_MAX_PAGES=5000
# Parallel marketplace workers for sweep (ThreadPoolExecutor max_workers cap)
BUYING_SWEEP_MAX_WORKERS=8
# Optional SOCKS5 for all B-Stock HTTP in apps.buying.services.scraper (requires PySocks).
# PIA: Dashboard -> VPN Settings -> SOCKS -> generate username/password (not your VPN login).
# Host e.g. proxy-nl.privateinternetaccess.com, port 1080. SOCKS != full VPN tunnel (unencrypted outer).
BUYING_SOCKS5_PROXY_ENABLED=False
BUYING_SOCKS5_PROXY_HOST=
BUYING_SOCKS5_PROXY_PORT=
BUYING_SOCKS5_PROXY_USER=
BUYING_SOCKS5_PROXY_PASSWORD=
# Optional: resolved IP of the proxy host (nslookup proxy-nl...). Overrides hostname in proxy URL.
# Fixes some setups where even socks5:// + hostname fails.
BUYING_SOCKS5_PROXY_IP=
# True (recommended for PIA) = socks5:// (this machine resolves hostnames then connects via proxy).
# False = socks5h:// (proxy resolves DNS). PIA's socks5h often fails with 0x04 Host unreachable.
BUYING_SOCKS5_LOCAL_DNS=True
# Dev: log redacted SOCKS URL per request + egress IP probes (logs/bstock_api.log)
BUYING_SOCKS5_DEV_AUDIT=False
BUYING_SOCKS5_EGRESS_PROBE_SECONDS=45
# SOCKS diagnostic (ipify + httpbin, optional B-Stock): python workspace/tests/socks5_egress_probe.py
