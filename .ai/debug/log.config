# ══════════════════════════════════════════════════════════════════════════════
# Dev Logging Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# AI INSTRUCTIONS:
# This file controls debug logging targets for the ecothrift application.
# To enable logging, set the desired key to a target value.
# Parent settings cascade to all children unless a child has its own value.
# After editing, Django auto-reloads; Vite needs restart for VITE_* changes in .env.
#
# TARGETS (set any key to one of these):
#   off     — disabled (default when absent or empty)
#   django  — Django runserver terminal (stderr)
#   browser — include debug payload in API JSON → Chrome DevTools console
#   file    — append to .ai/debug/debug.log
#   both    — django + browser
#   all     — django + browser + file
#
# HIERARCHY (indent is cosmetic; parents are defined in apps/core/log_config.py):
#
#   LOG_ALL
#   ├── LOG_BACKEND
#   │   ├── LOG_INVENTORY
#   │   │   ├── LOG_ADD_ITEM              ← Add Item (Inventory) umbrella
#   │   │   │   ├── LOG_ADD_ITEM_FORM     ← dialog open, Generate, create (browser + optional client→file)
#   │   │   │   └── LOG_ADD_ITEM_AI       ← AI prompt + raw model response (Add Item → Generate)
#   │   │   ├── LOG_INVENTORY_AI_CLEANUP  ← Manifest AI cleanup
#   │   │   ├── LOG_INVENTORY_AI_MATCH    ← AI product matching
#   │   │   ├── LOG_INVENTORY_AI_FINALIZATION
#   │   │   ├── LOG_INVENTORY_CATEGORIZER
#   │   │   ├── LOG_INVENTORY_PRICING
#   │   │   └── LOG_INVENTORY_IMPORT
#   │   ├── LOG_AI
#   │   ├── LOG_POS
#   │   └── LOG_AUTH
#   └── LOG_FRONTEND
#
# EXAMPLES:
#   LOG_ADD_ITEM = file          → Add Item: form + AI logs to .ai/debug/debug.log (children inherit)
#   LOG_ADD_ITEM_AI = all        → prompt/response + stderr + browser debug JSON
# ══════════════════════════════════════════════════════════════════════════════

# Add Item: log AI prompt + response and form actions to the AI log file (see .ai/debug/debug.log).
LOG_BACKEND = file
LOG_FRONTEND = file